{
  "name": "@grainulation/barn",
  "version": "1.2.0",
  "description": "Template browser and sprint toolkit for the grainulation ecosystem",
  "license": "MIT",
  "author": "grainulation contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grainulation/barn.git"
  },
  "homepage": "https://barn.grainulation.com",
  "bugs": {
    "url": "https://github.com/grainulation/barn/issues"
  },
  "keywords": [
    "wheat",
    "grainulation",
    "templates",
    "sprints",
    "structured-research",
    "developer-tools"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./server": "./lib/server.js",
    "./detect-sprints": "./tools/detect-sprints.js",
    "./generate-manifest": "./tools/generate-manifest.js",
    "./build-pdf": "./tools/build-pdf.js",
    "./mcp": { "import": "./lib/mcp.js", "require": "./lib/mcp.cjs" },
    "./paths": { "import": "./lib/paths.js", "require": "./lib/paths.cjs" },
    "./atomic": { "import": "./lib/atomic.js", "require": "./lib/atomic.cjs" },
    "./cli": { "import": "./lib/cli.js", "require": "./lib/cli.cjs" },
    "./phases": { "import": "./lib/phases.js", "require": "./lib/phases.cjs" },
    "./sprints": { "import": "./lib/sprints.js", "require": "./lib/sprints.cjs" },
    "./tokens": "./public/grainulation-tokens.css",
    "./status-icons": "./public/status-icons.svg"
  },
  "bin": {
    "barn": "./bin/barn.js"
  },
  "files": [
    "bin/",
    "lib/",
    "public/grainulation-tokens.css",
    "public/status-icons.svg",
    "public/grainulation-icons.svg",
    "tools/",
    "templates/",
    "CHANGELOG.md",
    "LICENSE",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "start": "node bin/barn.js serve",
    "serve": "node bin/barn.js serve",
    "test": "node test/basic.test.js && node --test test/shared-utils.test.js"
  },
  "engines": {
    "node": ">=20"
  }
}
